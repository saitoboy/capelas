generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────
enum Curso {
  TEOLOGIA
}

// ─── USUÁRIOS ────────────────────────────────────────────────────────────────
model Usuario {
  ra        String   @id @db.VarChar(20)
  nome      String   @db.VarChar(200)
  email     String   @unique @db.VarChar(255)
  senhaHash String   @map("senha_hash") @db.VarChar(255)
  curso     Curso
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")

  persona    Persona?
  relatorios Relatorio[]
  groqKeys   GroqKey[]

  @@map("usuarios")
}

// ─── PERSONA MBTI ─────────────────────────────────────────────────────────────
model Persona {
  id        String   @id @default(uuid())
  alunoRa   String   @unique @map("aluno_ra") @db.VarChar(20)
  tipo      String   @db.Char(4)
  nome      String   @db.VarChar(100)
  tom       String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  aluno Usuario @relation(fields: [alunoRa], references: [ra], onDelete: Cascade)

  @@map("personas")
}

// ─── SEMESTRES ────────────────────────────────────────────────────────────────
model Semestre {
  id              String   @id @default(uuid())
  label           String   @unique @db.VarChar(50)
  publishedAfter  DateTime @map("published_after")
  publishedBefore DateTime @map("published_before")
  ativo           Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  capelas    Capela[]
  relatorios Relatorio[]
  coletas    Coleta[]

  @@map("semestres")
}

// ─── COLETAS ──────────────────────────────────────────────────────────────────
// A coleta do YouTube faz ~3 chamadas de IA por capela e passa de 40 num semestre
// inteiro — não cabe num request HTTP. Roda em background e o front faz polling
// deste registro, igual ao Relatorio.
model Coleta {
  id          String   @id @default(uuid())
  semestreId  String   @map("semestre_id")
  status      String   @default("GERANDO") @db.VarChar(20) // GERANDO | CONCLUIDO | ERRO
  etapa       String?  @db.VarChar(160)                    // "Extraindo dados de ..."
  total       Int      @default(0)                         // capelas identificadas
  processadas Int      @default(0)
  inseridas   Int      @default(0)
  atualizadas Int      @default(0)
  ignorados   Int      @default(0)                         // vídeos descartados pelos filtros
  itens       Json?                                        // log por capela
  erroMsg     String?  @map("erro_msg")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  semestre Semestre @relation(fields: [semestreId], references: [id], onDelete: Cascade)

  @@index([semestreId])
  @@map("coletas")
}

// ─── CHAVES DA GROQ ───────────────────────────────────────────────────────────
// Fila de chaves. Ao bater o limite de tokens (429), a chave é marcada como
// ESGOTADA e a chamada é repetida na próxima da fila, de forma transparente.
model GroqKey {
  id         String    @id @default(uuid())
  label      String    @db.VarChar(60)  // apelido: "chave do Guilherme"
  keyEnc     String    @map("key_enc")  // AES-256-GCM — nunca sai do banco em texto puro
  preview    String    @db.VarChar(20)  // "gsk_…4f2a" — é só isto que a API devolve
  status     String    @default("ATIVA") @db.VarChar(12) // ATIVA | ESGOTADA | INVALIDA
  resetAt    DateTime? @map("reset_at")      // quando a Groq disse que o limite volta
  lastUsedAt DateTime? @map("last_used_at")  // ordena a fila (round-robin natural)
  erroMsg    String?   @map("erro_msg")
  tokensHoje Int       @default(0) @map("tokens_hoje") // tokens gastos na cota do dia
  tokensDia  DateTime? @map("tokens_dia") @db.Date     // dia (UTC) a que tokensHoje se refere
  criadoPor  String    @map("criado_por") @db.VarChar(20) // ra de quem cadastrou
  createdAt  DateTime  @default(now()) @map("created_at")

  aluno Usuario @relation(fields: [criadoPor], references: [ra], onDelete: Cascade)

  @@index([status, lastUsedAt])
  @@map("groq_keys")
}

// ─── CAPELAS ──────────────────────────────────────────────────────────────────
model Capela {
  id           String   @id @default(uuid())
  semestreId   String   @map("semestre_id")
  indice       Int
  data         DateTime @db.Date
  videoId      String?  @unique @map("video_id") @db.VarChar(20)
  url          String?  @db.VarChar(100)
  // Anuláveis de propósito: quando a IA não consegue extrair da pregação, o
  // campo fica NULL — não "(não encontrado)", que se confunde com dado real.
  // NULL é o sinal de "falta preencher à mão" (PATCH /capela/:id).
  textoBiblico String?  @map("texto_biblico") @db.VarChar(200)
  tema         String?  @db.VarChar(400)
  pregador     String?  @db.VarChar(200)
  source       String   @default("youtube") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  semestre Semestre @relation(fields: [semestreId], references: [id], onDelete: Cascade)
  sinopse  Sinopse?

  @@unique([semestreId, indice], name: "uk_semestre_indice")
  @@map("capelas")
}

// ─── SINOPSES ────────────────────────────────────────────────────────────────
model Sinopse {
  id       String   @id @default(uuid())
  capelaId String   @unique @map("capela_id")
  texto    String
  geradoEm DateTime @default(now()) @map("gerado_em")

  capela Capela @relation(fields: [capelaId], references: [id], onDelete: Cascade)

  @@map("sinopses")
}

// ─── RELATÓRIOS ───────────────────────────────────────────────────────────────
model Relatorio {
  id                String   @id @default(uuid())
  alunoRa           String   @map("aluno_ra") @db.VarChar(20)
  semestreId        String   @map("semestre_id")
  personaTipo       String   @db.Char(4) @map("persona_tipo")
  personaNome       String   @db.VarChar(100) @map("persona_nome")
  focoCriativo      String?  @db.VarChar(30) @map("foco_criativo")
  reflexaoTeologica String?  @map("reflexao_teologica")
  analiseLiturgica  String?  @map("analise_liturgica")
  status            String   @default("PENDENTE") @db.VarChar(20)
  erroMsg           String?  @map("erro_msg")
  docxData          String?  @map("docx_data")             // base64 do .docx gerado
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  aluno    Usuario  @relation(fields: [alunoRa], references: [ra], onDelete: Cascade)
  semestre Semestre @relation(fields: [semestreId], references: [id])

  @@unique([alunoRa, semestreId], name: "uk_aluno_semestre")
  @@map("relatorios")
}
