# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:senha@localhost:porta/nomedobanco"

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=porta
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=suasenha
JWT_EXPIRES_IN=7d

# ─── Groq AI ─────────────────────────────────────────────────────────────────
# Chave de fallback: usada só enquanto não houver nenhuma chave cadastrada em
# POST /groq-key. Cadastrada a primeira, a fila do banco assume.
GROQ_API_KEY=gsk_...

# Cota diária de tokens (TPD) do plano, por chave. É o número que aparece no
# console.groq.com em Settings › Limits para o modelo usado. Alimenta a barra
# de "% da cota usada hoje" na tela de chaves. Sem isto, a barra fica escondida.
GROQ_TPD=100000

# ─── Criptografia ─────────────────────────────────────────────────────────────
# Cifra as chaves da Groq em repouso (AES-256-GCM). Trocar esta chave torna
# ilegíveis as chaves já gravadas — elas serão marcadas como INVALIDA.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# ─── YouTube Data API ─────────────────────────────────────────────────────────
YOUTUBE_API_KEY=AIza...
CHANNEL_HANDLE=@souseminariodosul
CHAPEL_KEYWORD=Devoção na Capela
CHAPEL_WEEKDAY=2

# ─── Logo ─────────────────────────────────────────────────────────────────────
LOGO_URL=https://curriculo.digiescola.muriae.mg.gov.br/wp-content/uploads/2026/06/logo-fabat.png

# ─── Proxy (rede corporativa) ─────────────────────────────────────────────────
PROXY_HOST=ip
PROXY_PORT=porta
PROXY_USER=usuario
PROXY_PASS=senha
